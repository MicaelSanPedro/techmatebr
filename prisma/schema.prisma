generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FileEntry {
  id           String   @id @default(cuid())
  name         String
  originalName String
  size         Int
  type         String
  category     String   @default("outros")
  blobUrl      String
  downloads    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("file_entries")
}
